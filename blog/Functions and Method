QS : Create a function using "function" keyword that takes string as a argument and return the number of vowel in the string:

function countVowel(string){                    // declare the function
    let count = 0;
    for (let a of string){                      //using loop for checking every character is string
        if (a ==="a" || a === 'e' || a === 'i' || a === 'o' || a === 'u'){  //giving the conditons
            count++                   //if match conditions than count=count+1
        }
    }
    console.log(count)                          // print final count
}
countVowel('hemel')                             //calling the functions
countVowel('this is the end')                      //calling the functions

Output:
2    // cuz there is two vowel
4   // in 2nd call there is four vowel




